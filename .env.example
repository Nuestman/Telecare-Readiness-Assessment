# Copy to `.env` in the repo root and fill in values.
# On Replit, these are set in Secrets / the Replit database integration.

# Required — PostgreSQL connection string (same URL as Replit for shared data)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# API server (default matches Replit artifact config)
PORT=8080
NODE_ENV=development
ADMIN_KEY=aga-admin

# Frontend dev server (default matches Replit artifact config)
# VITE doesn't read root .env automatically; use the dev:local scripts or set in shell.
TELEHEALTH_PORT=21409
TELEHEALTH_BASE_PATH=/
