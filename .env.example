# Copy to `.env` in the repo root and fill in values.

# Required — PostgreSQL connection string
#
# Replit "development" URLs often use host `helium` (e.g. postgresql://...@helium/...).
# That hostname only resolves INSIDE a Replit workspace — db push and local `pnpm run dev`
# from your laptop cannot reach it. Use one of:
#   - The Neon *public* URL (…neon.tech…) for local work (same as production, or a dev branch)
#   - Run `pnpm --filter @workspace/db run push` in the Replit shell when using the helium URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# API server
PORT=8080
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# Survey collection window (optional — omit to keep always open)
# SURVEY_OPENS_AT=2026-01-01T00:00:00.000Z
# SURVEY_CLOSES_AT=2026-12-31T23:59:59.999Z
# SURVEY_MIN_SECONDS=30

# Production CORS (comma-separated origins)
# CORS_ORIGINS=https://your-replit-url.replit.app,http://localhost:21409

# Frontend dev server
TELEHEALTH_PORT=21409
TELEHEALTH_BASE_PATH=/

# System admin bootstrap (uses INITIAL_ADMIN_* as fallback if SYSTEM_ADMIN_* unset)
# SYSTEM_ADMIN_EMAIL=platform-admin@agahealthfoundation.org
# SYSTEM_ADMIN_PASSWORD=use-a-strong-password-min-12-chars
# SYSTEM_ADMIN_BOOTSTRAP_ENABLED=true

# Prospectus attachments (Vercel Blob — optional until upload is needed)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
