{
  "name": "workspace",
  "version": "1.1.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.includes('pnpm')){console.error('Use pnpm instead'); process.exit(1)} try{require('fs').unlinkSync('package-lock.json')}catch{} try{require('fs').unlinkSync('yarn.lock')}catch{}\"",
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-local.ps1",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "db:migrate:platform": "pnpm --filter @workspace/db run migrate:platform",
    "db:migrate:prospectus": "pnpm --filter @workspace/db run migrate:prospectus"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  }
}
